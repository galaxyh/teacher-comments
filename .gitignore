# ─────────────────────────────────────────────────────────────────────
# Governance kit additions — append these blocks to your .gitignore
# ─────────────────────────────────────────────────────────────────────

# --- Claude Code (project-level) ---
# Personal permissions — do NOT commit (may contain absolute paths, user-specific allows)
.claude/settings.json
.claude/settings.local.json

# Project-level Claude Code commands & skills — personal dev tooling,
# NOT a project requirement. Each developer sets up their own (or skips entirely).
.claude/commands/
.claude/skills/

# --- Lychee link checker cache ---
.lycheecache

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Backend runtime data (per ARCH-001 §5.1: SQLite DB + WAL + audio cache) ---
backend/data/
backend/tmp/

# --- Env files (contain secrets) ---
.env
.env.local
backend/.env
backend/.env.local

# --- Frontend ---
node_modules/
.next/
.turbo/
dist/
build/
*.tsbuildinfo

# --- IDE ---
.vscode/
.idea/
*.swp
