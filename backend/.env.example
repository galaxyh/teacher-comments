# ──────────────────────────────────────────────────────────────────────
# teacher-comments backend — env vars (per ARCH-001 §5.3)
# Copy to .env and fill in real values; .env is .gitignore'd.
# Generate AES-256 keys: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# ──────────────────────────────────────────────────────────────────────

# DB (D16: SQLite + WAL + aiosqlite)
DATABASE_URL=sqlite+aiosqlite:///./data/teacher.db

# OAuth (Google Cloud Console → OAuth client ID → Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# PUBLIC_BASE_URL must be the *frontend* origin the user's browser sees, NOT the backend.
# OAuth callback uses {PUBLIC_BASE_URL}/auth/callback and falls back to {PUBLIC_BASE_URL}/
# after success — if you point this at :8000 in dev, the post-login redirect lands on
# the bare backend (404, no UI) instead of the Next.js frontend. Register the matching
# URI in Google Cloud Console → Credentials → Authorized redirect URIs.
# Dev:  http://localhost:3000   (Next.js dev server proxies /auth/* → backend :8000)
# Prod: https://teacher.example.com  (Caddy/Cloudflare terminates TLS, routes to both)
PUBLIC_BASE_URL=http://localhost:3000

# OpenRouter (D8/D9 — Flash Lite default for all tiers)
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # override for tests / private deployments

# LLM tier overrides (optional — defaults from app/config.py)
# LLM_TIER_SUMMARY_CHEAP=google/gemini-2.5-flash-lite
# LLM_TIER_VISION_CHEAP=google/gemini-2.5-flash-lite
# LLM_TIER_AUDIO_STANDARD=google/gemini-2.5-flash-lite
# LLM_TIER_EVALUATION_QUALITY=google/gemini-2.5-flash-lite

# Crypto (per-record nonce, AES-256-GCM)
PII_ENCRYPTION_KEY=
OAUTH_TOKEN_ENCRYPTION_KEY=

# Session cookie signing (separate from data encryption)
SESSION_SECRET_KEY=

# Optional tuning
# BATCH_WORKER_CONCURRENCY=4
# BUDGET_MONTHLY_USD=5.00
# LOG_LEVEL=INFO
# SENTRY_DSN=
